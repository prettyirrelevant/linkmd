{
  "name": "linkmd",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "bun run typecheck && bun run test && bun run build",
    "build": "bun build src/main.ts --compile --minify --no-compile-autoload-dotenv --no-compile-autoload-bunfig --outfile dist/linkmd"
  },
  "dependencies": {
    "@effect/cli": "0.76.0",
    "@effect/platform": "0.97.0",
    "@effect/platform-bun": "0.91.0",
    "effect": "3.22.0",
    "smol-toml": "1.7.0"
  },
  "devDependencies": {
    "@effect/vitest": "0.30.0",
    "@types/bun": "1.3.14",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  }
}
